<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="@drawable/bg_dropdown_button"
    android:layout_marginHorizontal="16dp"
    android:layout_marginBottom="8dp"
    android:padding="12dp"
    android:gravity="center_vertical"
    android:orientation="horizontal">

    <ImageView
        android:id="@+id/imgGenreAvatar"
        android:layout_width="50dp"
        android:layout_height="50dp"
        android:scaleType="centerCrop"
        android:src="@drawable/ic_musical_notes" />

    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:layout_marginStart="12dp"
        android:orientation="vertical">

        <TextView
            android:id="@+id/textGenreName"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Genre Name"
            android:textColor="@color/white"
            android:textSize="14sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/textGenreDescription"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Description"
            android:textColor="@color/textSecondary"
            android:textSize="12sp"
            android:maxLines="2"
            android:ellipsize="end" />
    </LinearLayout>

    <LinearLayout
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:gravity="center"
        android:paddingStart="12dp"
        android:orientation="vertical">

        <TextView
            android:id="@+id/textGenreCount"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="0"
            android:textColor="@color/vibrant_purple"
            android:textSize="16sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/textGenreCountLabel"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="bài hát"
            android:textColor="@color/textMuted"
            android:textSize="10sp" />
    </LinearLayout>
</LinearLayout>
