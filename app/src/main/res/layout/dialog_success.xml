<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    app:cardBackgroundColor="#1F1F1F"
    app:cardCornerRadius="24dp"
    app:cardElevation="8dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center"
        android:orientation="vertical"
        android:padding="24dp">

        <View
            android:layout_width="80dp"
            android:layout_height="80dp"
            android:background="@drawable/circle_success_bg" />

        <ImageView
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:layout_marginTop="-64dp"
            android:src="@android:drawable/checkbox_on_background"
            app:tint="#4CAF50" />

        <TextView
            android:id="@+id/txtSuccessTitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="32dp"
            android:text="Thành công!"
            android:textColor="#FFFFFF"
            android:textSize="20sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/txtSuccessMessage"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:gravity="center"
            android:text="Giao dịch của bạn đã được thực hiện."
            android:textColor="#B3FFFFFF"
            android:textSize="14sp" />

        <Button
            android:id="@+id/btnSuccessDone"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            android:backgroundTint="#4CAF50"
            android:text="Tuyệt vời"
            android:textAllCaps="false"
            android:textColor="#FFFFFF" />

    </LinearLayout>

</com.google.android.material.card.MaterialCardView>
