<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/llSongBody"
    android:layout_width="match_parent"
    android:layout_height="108dp"
    android:layout_marginHorizontal="12dp"
    android:layout_marginVertical="6dp"
    android:background="@drawable/bg_song_card"
    android:clickable="true"
    android:focusable="true"
    android:padding="10dp">

    <!-- Album Cover (Vertical Center) -->
    <com.google.android.material.imageview.ShapeableImageView
        android:id="@+id/imgSongCover"
        android:layout_width="64dp"
        android:layout_height="64dp"
        android:scaleType="centerCrop"
        android:src="@drawable/ic_launcher_background"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:shapeAppearanceOverlay="@style/RoundedImage" />

    <!-- Actions Area (Right Side) - Fixed Width first to anchor text -->
    <LinearLayout
        android:id="@+id/actionsArea"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:gravity="end"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="parent">

            <!-- Top Right: Premium Text Badge (Shifted slightly) -->
            <com.appad.components.PremiumBadgeView
                android:id="@+id/badgePremium"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginBottom="8dp"
                android:translationX="-5dp"
                android:visibility="gone" />

        <!-- Bottom Right: Play & Remove -->
        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:orientation="horizontal">
            <ImageButton
                android:id="@+id/btnPlayFast"
                android:layout_width="36dp"
                android:layout_height="36dp"
                android:background="@drawable/circle_button_bg"
                android:backgroundTint="#2D2D2D"
                android:padding="8dp"
                android:scaleType="centerInside"
                android:src="@android:drawable/ic_media_play"
                app:tint="#8B5CF6" />
            
            <!-- Remove Button: Red X -->
            <ImageButton
                android:id="@+id/btnRemove"
                android:layout_width="32dp"
                android:layout_height="32dp"
                android:layout_marginStart="8dp"
                android:background="@drawable/circle_button_bg"
                android:backgroundTint="#26EF4444"
                android:padding="8dp"
                android:scaleType="centerInside"
                android:src="@drawable/ic_remove_red"
                app:tint="#EF4444" />
        </LinearLayout>
    </LinearLayout>

    <!-- Info Content (Fills remaining space) -->
    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="12dp"
        android:layout_marginEnd="8dp"
        android:orientation="vertical"
        android:gravity="center_vertical"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toStartOf="@+id/actionsArea"
        app:layout_constraintStart_toEndOf="@+id/imgSongCover"
        app:layout_constraintTop_toTopOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:orientation="horizontal">
            <TextView
                android:id="@+id/textSongTitle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:ellipsize="end"
                android:maxLines="1"
                android:text="Song Title"
                android:textColor="#FFFFFF"
                android:textSize="16sp"
                android:textStyle="bold" />

            <com.appad.components.AccessBadgeView
                android:id="@+id/accessBadge"
                android:layout_width="16dp"
                android:layout_height="16dp"
                android:layout_marginStart="6dp"
                android:visibility="gone" />
        </LinearLayout>

        <TextView
            android:id="@+id/textArtistGenre"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="2dp"
            android:ellipsize="end"
            android:maxLines="1"
            android:text="Artist Name"
            android:textColor="#B3B3B3"
            android:textSize="13sp" />

        <!-- Stats Row -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <!-- Listens -->
            <ImageView
                android:layout_width="12dp"
                android:layout_height="12dp"
                android:src="@android:drawable/stat_sys_phone_call"
                app:tint="#888888" />
            <TextView
                android:id="@+id/textListens"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="4dp"
                android:text="0"
                android:textColor="#888888"
                android:textSize="11sp"
                android:maxLines="1"/>

            <!-- Rating -->
            <ImageView
                android:layout_width="12dp"
                android:layout_height="12dp"
                android:layout_marginStart="12dp"
                android:src="@android:drawable/btn_star_big_on"
                app:tint="#F59E0B" />
            <TextView
                android:id="@+id/textStars"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="4dp"
                android:text="0.0"
                android:textColor="#888888"
                android:textSize="11sp" />

            <!-- Duration -->
            <ImageView
                android:layout_width="12dp"
                android:layout_height="12dp"
                android:layout_marginStart="12dp"
                android:src="@android:drawable/ic_lock_idle_alarm"
                app:tint="#888888" />
            <TextView
                android:id="@+id/textDuration"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginStart="4dp"
                android:text="0:00"
                android:textColor="#888888"
                android:textSize="11sp"
                android:maxLines="1"
                android:ellipsize="end"/>
        </LinearLayout>
    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>
