<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#0A0A0A">

    <androidx.swiperefreshlayout.widget.SwipeRefreshLayout
        android:id="@+id/swipeRefreshWallet"
        android:layout_width="match_parent"
        android:layout_height="match_parent">

        <androidx.core.widget.NestedScrollView
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:fillViewport="true">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:paddingBottom="100dp">

                <!-- Header -->
                <RelativeLayout
                    android:layout_width="match_parent"
                    android:layout_height="280dp">

                    <View
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:background="@drawable/home_top_gradient" />

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:paddingHorizontal="20dp"
                        android:paddingTop="48dp"
                        android:gravity="center_vertical">
                        
                        <ImageButton
                            android:id="@+id/btnBack"
                            android:layout_width="40dp"
                            android:layout_height="40dp"
                            android:background="@drawable/bg_circle_translucent"
                            android:src="@drawable/ic_back"
                            app:tint="#FFFFFF"
                            android:padding="10dp"
                            android:scaleType="centerInside" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="16dp"
                            android:text="Ví của tôi"
                            android:textColor="#FFFFFF"
                            android:textSize="22sp"
                            android:fontFamily="sans-serif-medium" />
                    </LinearLayout>

                    <!-- Wallet Card -->
                    <androidx.cardview.widget.CardView
                        android:id="@+id/walletCard"
                        android:layout_width="match_parent"
                        android:layout_height="180dp"
                        android:layout_alignParentBottom="true"
                        android:layout_marginHorizontal="20dp"
                        android:layout_marginBottom="10dp"
                        app:cardCornerRadius="24dp"
                        app:cardElevation="10dp"
                        app:cardBackgroundColor="?android:attr/colorBackground">

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:background="@drawable/bg_wallet_card_gradient"
                            android:orientation="vertical"
                            android:padding="24dp">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="SỐ DƯ HIỆN TẠI"
                                android:textColor="#B3FFFFFF"
                                android:textSize="12sp"
                                android:textStyle="bold"
                                android:letterSpacing="0.1" />

                            <TextView
                                android:id="@+id/txtBalance"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="8dp"
                                android:text="0đ"
                                android:textColor="#FFFFFF"
                                android:textSize="36sp"
                                android:fontFamily="sans-serif-black" />

                            <View android:layout_width="0dp" android:layout_height="0dp" android:layout_weight="1" />

                            <LinearLayout
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:orientation="horizontal"
                                android:gravity="center_vertical">

                                <com.google.android.material.button.MaterialButton
                                    android:id="@+id/btnDeposit"
                                    android:layout_width="wrap_content"
                                    android:layout_height="40dp"
                                    android:text="Nạp tiền"
                                    android:textColor="#FFFFFF"
                                    app:backgroundTint="#33FFFFFF"
                                    app:icon="@drawable/ic_add"
                                    app:iconTint="#FFFFFF"
                                    app:iconSize="18dp"
                                    app:cornerRadius="20dp"
                                    android:paddingHorizontal="20dp"
                                    android:insetTop="0dp"
                                    android:insetBottom="0dp"
                                    android:textSize="13sp"
                                    android:textStyle="bold"
                                    style="@style/Widget.MaterialComponents.Button.UnelevatedButton" />

                                <View android:layout_width="0dp" android:layout_height="0dp" android:layout_weight="1" />

                                <ImageView
                                    android:layout_width="48dp"
                                    android:layout_height="48dp"
                                    android:src="@drawable/ic_wallet"
                                    android:alpha="0.2"
                                    app:tint="#FFFFFF" />
                            </LinearLayout>
                        </LinearLayout>
                    </androidx.cardview.widget.CardView>
                </RelativeLayout>



                <!-- Recent Transactions Header -->
                <RelativeLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="32dp"
                    android:paddingHorizontal="24dp">
                    
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Giao dịch gần đây"
                        android:textColor="#FFFFFF"
                        android:textSize="18sp"
                        android:fontFamily="sans-serif-medium" />
                    
                    <TextView
                        android:id="@+id/btnViewAllTransactions"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_alignParentRight="true"
                        android:layout_centerVertical="true"
                        android:text="Xem tất cả"
                        android:textColor="#A78BFA"
                        android:textSize="14sp"
                        android:textStyle="bold"
                        android:paddingVertical="4dp"
                        android:paddingHorizontal="8dp"
                        android:background="?attr/selectableItemBackground" />
                </RelativeLayout>

                <!-- Transactions List -->
                <androidx.cardview.widget.CardView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginHorizontal="20dp"
                    android:layout_marginTop="16dp"
                    app:cardCornerRadius="20dp"
                    app:cardElevation="2dp"
                    app:cardBackgroundColor="#1A1A1A">
                    
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical">

                        <androidx.recyclerview.widget.RecyclerView
                            android:id="@+id/rvRecentTransactions"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:nestedScrollingEnabled="false" />

                        <TextView
                            android:id="@+id/txtNoTransactions"
                            android:layout_width="match_parent"
                            android:layout_height="120dp"
                            android:gravity="center"
                            android:text="Chưa có giao dịch nào"
                            android:textColor="#6B7280"
                            android:textSize="15sp"
                            android:visibility="gone" />
                    </LinearLayout>
                </androidx.cardview.widget.CardView>

            </LinearLayout>
        </androidx.core.widget.NestedScrollView>
    </androidx.swiperefreshlayout.widget.SwipeRefreshLayout>

    <include
        android:id="@+id/miniPlayerContainer"
        layout="@layout/layout_mini_player"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_alignParentBottom="true"
        android:layout_marginBottom="16dp" />

</RelativeLayout>
