<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#121212">

    <!-- Blurred Background Image -->
    <ImageView
        android:id="@+id/imgBackground"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:scaleType="centerCrop"
        android:alpha="0.4" />

    <!-- Dark Overlay for better readability -->
    <View
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="@drawable/bg_gradient_overlay" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical">

        <!-- Header -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:paddingHorizontal="16dp"
            android:paddingVertical="12dp">

            <ImageButton
                android:id="@+id/btnBack"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:background="@drawable/circle_button_bg"
                android:backgroundTint="#33FFFFFF"
                android:src="@drawable/ic_chevron_left"
                app:tint="#FFFFFF"
                android:padding="8dp"/>

            <TextView
                android:id="@+id/txtPlaylistTitle"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginHorizontal="12dp"
                android:text="Playlist"
                android:textColor="#FFFFFF"
                android:textSize="20sp"
                android:textStyle="bold"
                android:ellipsize="end"
                android:maxLines="1"/>

            <!-- Change Cover Button -->
            <ImageButton
                android:id="@+id/btnChangeCover"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:layout_marginEnd="8dp"
                android:background="@drawable/circle_button_bg"
                android:backgroundTint="#33FFFFFF"
                android:src="@drawable/ic_camera"
                app:tint="#FFFFFF"
                android:padding="8dp"/>

            <!-- Share Button -->
            <ImageButton
                android:id="@+id/btnShare"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:layout_marginEnd="8dp"
                android:background="@drawable/circle_button_bg"
                android:backgroundTint="#33FFFFFF"
                android:src="@drawable/ic_share"
                app:tint="#FFFFFF"
                android:padding="8dp"/>

            <ImageButton
                android:id="@+id/btnPlayAll"
                android:layout_width="44dp"
                android:layout_height="44dp"
                android:background="@drawable/bg_play_gradient"
                android:src="@android:drawable/ic_media_play"
                app:tint="#FFFFFF"
                android:scaleType="centerInside"
                android:padding="10dp"/>
        </LinearLayout>

        <!-- Song List -->
        <ProgressBar
            android:id="@+id/progressBar"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:visibility="gone"/>

        <TextView
            android:id="@+id/txtEmpty"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:text="Playlist này chưa có bài hát nào"
            android:textColor="#CCCCCC"
            android:textSize="14sp"
            android:visibility="gone"
            android:layout_marginTop="32dp"/>

        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/rvPlaylistSongs"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:padding="8dp"
            android:clipToPadding="false"/>
    </LinearLayout>

    <!-- Hidden views for compatibility -->
    <ImageView
        android:id="@+id/imgPlaylistCover"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:visibility="gone"/>
    
    <TextView
        android:id="@+id/txtPlaylistName"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:visibility="gone"/>
    
    <TextView
        android:id="@+id/txtPlaylistSongCount"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:visibility="gone"/>
    
    <TextView
        android:id="@+id/txtPlaylistDescription"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:visibility="gone"/>

    <include
        android:id="@+id/miniPlayerContainer"
        layout="@layout/layout_mini_player"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_alignParentBottom="true"
        android:layout_marginBottom="16dp" />

</RelativeLayout>
