<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#121212"
    android:orientation="vertical">

    <RelativeLayout
        android:id="@+id/headerEditAlbum"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="#1E1E1E"
        android:paddingBottom="16dp">
        
        <ImageButton
            android:id="@+id/btnBack"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:src="@android:drawable/ic_menu_revert"
            app:tint="#FFFFFF" />

        <TextView
            android:id="@+id/txtHeaderTitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_centerHorizontal="true"
            android:layout_marginTop="12dp"
            android:text="THÊM ALBUM MỚI"
            android:textColor="#FFFFFF"
            android:textSize="14sp"
            android:textStyle="bold"
            android:letterSpacing="0.1" />

        <TextView
            android:id="@+id/btnSave"
            android:layout_width="wrap_content"
            android:layout_height="48dp"
            android:layout_alignParentEnd="true"
            android:gravity="center"
            android:paddingHorizontal="16dp"
            android:text="Lưu"
            android:textColor="#8b5cf6"
            android:textSize="14sp"
            android:textStyle="bold" />
    </RelativeLayout>

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:padding="20dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingBottom="50dp">
            
            <!-- Cover Upload Section -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center_horizontal"
                android:orientation="vertical"
                android:layout_marginBottom="32dp">

                <RelativeLayout
                    android:id="@+id/layoutCover"
                    android:layout_width="140dp"
                    android:layout_height="140dp"
                    android:layout_marginBottom="20dp">

                    <com.google.android.material.imageview.ShapeableImageView
                        android:id="@+id/imgCover"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:background="#2A2A2A"
                        android:src="@drawable/ic_nav_library"
                        android:scaleType="centerCrop"
                        app:shapeAppearanceOverlay="@style/RoundedCornerImage24"
                        app:tint="#555" />
                    
                    <ProgressBar
                        android:id="@+id/progressCover"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_centerInParent="true"
                        android:visibility="gone" />

                    <FrameLayout
                        android:layout_width="32dp"
                        android:layout_height="32dp"
                        android:layout_alignParentEnd="true"
                        android:layout_alignParentBottom="true"
                        android:layout_margin="5dp"
                        android:background="@drawable/bg_admin_menu_icon_rounded"
                        android:backgroundTint="#8b5cf6">
                        <ImageView
                            android:layout_width="16dp"
                            android:layout_height="16dp"
                            android:layout_gravity="center"
                            android:src="@android:drawable/ic_menu_camera"
                            app:tint="#FFFFFF" />
                    </FrameLayout>
                </RelativeLayout>
                
                <TextView
                    android:id="@+id/txtCoverStatus"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Chọn ảnh bìa album"
                    android:textColor="#888888"
                    android:textSize="12sp" />
            </LinearLayout>

            <!-- Form Fields -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardBackgroundColor="#1A1A1A"
                app:cardCornerRadius="24dp"
                app:cardElevation="0dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="20dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Tên Album *"
                        android:textColor="#888888"
                        android:textSize="13sp"
                        android:textStyle="bold"
                        android:layout_marginBottom="8dp" />
                    
                    <EditText
                        android:id="@+id/edtTitle"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:background="@drawable/bg_search_input"
                        android:backgroundTint="#08FFFFFF"
                        android:padding="14dp"
                        android:textColor="#FFFFFF"
                        android:hint="Nhập tên album..."
                        android:textColorHint="#555555"
                        android:textSize="14sp"
                        android:layout_marginBottom="20dp" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Nghệ sĩ sở hữu *"
                        android:textColor="#888888"
                        android:textSize="13sp"
                        android:textStyle="bold"
                        android:layout_marginBottom="8dp" />
                    
                    <TextView
                        android:id="@+id/txtSelectorArtist"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:background="@drawable/bg_search_input"
                        android:backgroundTint="#08FFFFFF"
                        android:padding="14dp"
                        android:text="Chọn nghệ sĩ..."
                        android:textColor="#FFFFFF"
                        android:layout_marginBottom="20dp"
                        app:drawableEndCompat="@android:drawable/arrow_down_float"
                        app:drawableTint="#555555" />

                     <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Ngày phát hành"
                        android:textColor="#888888"
                        android:textSize="13sp"
                        android:textStyle="bold"
                        android:layout_marginBottom="8dp" />
                    
                    <EditText
                        android:id="@+id/edtReleaseDate"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:background="@drawable/bg_search_input"
                        android:backgroundTint="#08FFFFFF"
                        android:padding="14dp"
                        android:textColor="#FFFFFF"
                        android:hint="YYYY-MM-DD"
                        android:textColorHint="#555555"
                        android:textSize="14sp"
                        android:layout_marginBottom="20dp" />

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:paddingVertical="16dp"
                        android:layout_marginBottom="20dp">
                        
                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical">
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Album Premium"
                                android:textColor="#FFFFFF"
                                android:textSize="15sp"
                                android:textStyle="bold" />
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Người dùng cần mua để nghe"
                                android:textColor="#666666"
                                android:textSize="12sp"
                                android:layout_marginTop="2dp" />
                        </LinearLayout>
                        
                        <com.google.android.material.switchmaterial.SwitchMaterial
                            android:id="@+id/switchPremium"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                             />
                    </LinearLayout>

                    <LinearLayout
                        android:id="@+id/layoutPrice"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:visibility="gone">
                         <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Giá bán (VNĐ)"
                            android:textColor="#888888"
                            android:textSize="13sp"
                            android:textStyle="bold"
                            android:layout_marginBottom="8dp" />
                        
                        <EditText
                            android:id="@+id/edtPrice"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:background="@drawable/bg_search_input"
                            android:backgroundTint="#08FFFFFF"
                            android:padding="14dp"
                            android:textColor="#FFFFFF"
                            android:hint="0"
                            android:inputType="number"
                            android:textColorHint="#555555"
                            android:textSize="14sp"
                            android:layout_marginBottom="20dp" />
                    </LinearLayout>

                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- Songs List Section (Only in Edit Mode) -->
            <LinearLayout
                android:id="@+id/layoutSongs"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:layout_marginTop="32dp"
                android:visibility="gone">
                
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center_vertical"
                    android:orientation="horizontal"
                    android:layout_marginBottom="16dp">

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical">
                         <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="DANH SÁCH BÀI HÁT"
                            android:textColor="#FFFFFF"
                            android:textSize="12sp"
                            android:textStyle="bold"
                            android:letterSpacing="0.15" />
                         <TextView
                             android:id="@+id/txtSongCount"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="0 bài hát trong album"
                            android:textColor="#888888"
                            android:textSize="11sp" />
                    </LinearLayout>

                    <TextView
                        android:id="@+id/btnAddSongToAlbum"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:background="@drawable/bg_admin_menu_icon_rounded"
                        android:backgroundTint="#10B981"
                        android:text="+ Thêm"
                        android:textColor="#000000"
                        android:textSize="12sp"
                        android:textStyle="bold"
                        android:paddingHorizontal="12dp"
                        android:paddingVertical="6dp" />
                </LinearLayout>

                <LinearLayout
                     android:id="@+id/containerSongs"
                     android:layout_width="match_parent"
                     android:layout_height="wrap_content"
                     android:orientation="vertical"
                     android:background="@drawable/bg_search_input"
                     android:backgroundTint="#05FFFFFF"
                     android:padding="4dp" />

            </LinearLayout>

            <TextView
                android:id="@+id/btnDeleteAlbum"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="40dp"
                android:gravity="center"
                 android:padding="16dp"
                android:background="@drawable/bg_search_input"
                 android:backgroundTint="#10EF4444"
                android:text="XÓA VĨNH VIỄN ALBUM NÀY"
                android:textColor="#EF4444"
                android:textStyle="bold"
                android:textSize="13sp"
                android:visibility="gone" />

        </LinearLayout>
    </ScrollView>
</LinearLayout>
