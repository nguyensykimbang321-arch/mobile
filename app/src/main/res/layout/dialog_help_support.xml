<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:padding="24dp"
    android:background="@drawable/bg_bottom_sheet"
    android:backgroundTint="#1E1E1E">

    <!-- Title -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Trợ giúp &amp; Hỗ trợ"
        android:textColor="#FFFFFF"
        android:textSize="20sp"
        android:textStyle="bold"
        android:layout_gravity="center_horizontal"
        android:layout_marginBottom="8dp"/>

    <!-- Subtitle -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Chọn phương thức liên hệ để nhận sự trợ giúp nhanh nhất từ chúng tôi."
        android:textColor="#AAAAAA"
        android:textSize="13sp"
        android:layout_gravity="center_horizontal"
        android:gravity="center"
        android:layout_marginBottom="24dp"/>

    <!-- Options Container -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:background="@drawable/bg_glass_card"
        android:layout_marginBottom="24dp">

        <!-- Facebook Row -->
        <LinearLayout
            android:id="@+id/btnHelpFacebook"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:padding="16dp"
            android:clickable="true"
            android:focusable="true"
            android:background="?attr/selectableItemBackground">
            <ImageView
                android:layout_width="44dp"
                android:layout_height="44dp"
                android:background="@drawable/circle_button_bg"
                android:backgroundTint="#1877F2"
                android:padding="10dp"
                android:src="@drawable/ic_facebook"
                app:tint="#FFF"/>
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginStart="16dp"
                android:orientation="vertical">
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Liên hệ qua Facebook"
                    android:textColor="#FFF"
                    android:textStyle="bold"
                    android:textSize="15sp"/>
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Gửi tin nhắn hỗ trợ trực tiếp"
                    android:textColor="#888888"
                    android:textSize="12sp"
                    android:layout_marginTop="2dp"/>
            </LinearLayout>
            <ImageView
                android:layout_width="20dp"
                android:layout_height="20dp"
                android:src="@drawable/ic_chevron_right"
                app:tint="#888888"/>
        </LinearLayout>

        <!-- Divider -->
        <View 
            android:layout_width="match_parent" 
            android:layout_height="1dp" 
            android:background="#1AFFFFFF" 
            android:layout_marginHorizontal="16dp"/>

        <!-- Email Row -->
        <LinearLayout
            android:id="@+id/btnHelpEmail"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:padding="16dp"
            android:clickable="true"
            android:focusable="true"
            android:background="?attr/selectableItemBackground">
            <ImageView
                android:layout_width="44dp"
                android:layout_height="44dp"
                android:background="@drawable/circle_button_bg"
                android:backgroundTint="#EA4335"
                android:padding="10dp"
                android:src="@drawable/ic_email"
                app:tint="#FFF"/>
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginStart="16dp"
                android:orientation="vertical">
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Gửi phản hồi qua Email"
                    android:textColor="#FFF"
                    android:textStyle="bold"
                    android:textSize="15sp"/>
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="nguyensykimbang324@gmail.com"
                    android:textColor="#888888"
                    android:textSize="12sp"
                    android:layout_marginTop="2dp"/>
            </LinearLayout>
            <ImageView
                android:layout_width="20dp"
                android:layout_height="20dp"
                android:src="@drawable/ic_chevron_right"
                app:tint="#888888"/>
        </LinearLayout>
    </LinearLayout>

    <!-- Close Button -->
    <Button
        android:id="@+id/btnHelpClose"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Đóng"
        android:backgroundTint="#2D2D2D"
        android:textColor="#FFFFFF"
        android:textAllCaps="false"
        android:textStyle="bold"/>

</LinearLayout>
