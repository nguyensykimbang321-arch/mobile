<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#0a0a0a"
    android:orientation="vertical">

    <androidx.appcompat.widget.Toolbar
        android:id="@+id/toolbar"
        android:layout_width="match_parent"
        android:layout_height="?attr/actionBarSize"
        android:background="#121212"
        app:title="Gửi thông báo hệ thống"
        app:titleTextColor="#ffffff"
        app:navigationIcon="@drawable/ic_back"/>

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:padding="20dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Tiêu đề thông báo"
                android:textColor="#888"
                android:textSize="14sp"
                android:layout_marginBottom="8dp"/>

            <EditText
                android:id="@+id/edtTitle"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_glass_card"
                android:padding="12dp"
                android:textColor="#fff"
                android:hint="Nhập tiêu đề..."
                android:textColorHint="#444"
                android:layout_marginBottom="24dp"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Nội dung thông báo"
                android:textColor="#888"
                android:textSize="14sp"
                android:layout_marginBottom="8dp"/>

            <EditText
                android:id="@+id/edtMessage"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:minLines="5"
                android:gravity="top"
                android:background="@drawable/bg_glass_card"
                android:padding="12dp"
                android:textColor="#fff"
                android:hint="Nhập nội dung thông báo cho toàn bộ người dùng..."
                android:textColorHint="#444"
                android:layout_marginBottom="32dp"/>

            <Button
                android:id="@+id/btnSend"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:text="Gửi thông báo ngay"
                android:textAllCaps="false"
                android:backgroundTint="#8B5CF6"
                android:textColor="#fff"
                app:cornerRadius="12dp"/>
                
        </LinearLayout>
    </ScrollView>

</LinearLayout>
