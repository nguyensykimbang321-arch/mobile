<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="12dp"
    app:cardBackgroundColor="#1A1A1A"
    app:cardCornerRadius="16dp"
    app:cardElevation="0dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:padding="12dp"
        android:gravity="center_vertical">

        <com.google.android.material.imageview.ShapeableImageView
            android:id="@+id/imgAlbumCover"
            android:layout_width="70dp"
            android:layout_height="70dp"
            android:scaleType="centerCrop"
            android:src="@drawable/placeholder_song"
            app:shapeAppearanceOverlay="@style/RoundedImage8" />

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="16dp"
            android:layout_weight="1"
            android:orientation="vertical">

            <TextView
                android:id="@+id/txtAlbumTitle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Album Title"
                android:textColor="#FFFFFF"
                android:textSize="16sp"
                android:textStyle="bold"
                android:ellipsize="end"
                android:maxLines="1" />

            <TextView
                android:id="@+id/txtAlbumArtist"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Artist Name"
                android:textColor="#888888"
                android:textSize="13sp"
                android:layout_marginTop="2dp" />

            <TextView
                android:id="@+id/txtAlbumSongs"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="0 bài hát"
                android:textColor="#F59E0B"
                android:textSize="12sp"
                android:layout_marginTop="4dp"
                android:textStyle="bold" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal">

            <ImageButton
                android:id="@+id/btnEditAlbum"
                android:layout_width="38dp"
                android:layout_height="38dp"
                android:background="@drawable/bg_admin_menu_icon_rounded"
                android:src="@android:drawable/ic_menu_edit"
                app:tint="#F59E0B"
                android:backgroundTint="#20F59E0B" />

            <ImageButton
                android:id="@+id/btnDeleteAlbum"
                android:layout_width="38dp"
                android:layout_height="38dp"
                android:layout_marginStart="8dp"
                android:background="@drawable/bg_admin_menu_icon_rounded"
                android:src="@android:drawable/ic_menu_delete"
                app:tint="#EF4444"
                android:backgroundTint="#15EF4444" />
        </LinearLayout>
    </LinearLayout>
</androidx.cardview.widget.CardView>
