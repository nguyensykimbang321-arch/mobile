<androidx.core.widget.NestedScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/playerRootLayout"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/player_background_gradient"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="20dp"
        android:clipChildren="false"
        android:clipToPadding="false">

        <!-- Header / Toolbar -->
        <androidx.constraintlayout.widget.ConstraintLayout
            android:id="@+id/headerLayout"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp">

            <ImageButton
                android:id="@+id/btnBack"
                android:layout_width="44dp"
                android:layout_height="44dp"
                android:background="@drawable/bg_back_button_fixed"
                android:padding="12dp"
                android:scaleType="centerInside"
                android:src="@drawable/ic_back"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="parent"
                app:tint="@color/white" />

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:gravity="center"
                android:orientation="vertical"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="parent">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:alpha="0.7"
                    android:letterSpacing="0.1"
                    android:text="PHÁT TỪ DANH SÁCH"
                    android:textColor="@color/white"
                    android:textSize="10sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/textGenre"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Giai điệu Gây nghiện"
                    android:textColor="@color/white"
                    android:textSize="14sp"
                    android:textStyle="bold" />
            </LinearLayout>

            <ImageButton
                android:id="@+id/btnMoreActions"
                android:layout_width="44dp"
                android:layout_height="44dp"
                android:background="@drawable/glass_circle_bg"
                android:src="@android:drawable/ic_menu_more"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintTop_toTopOf="parent"
                app:tint="@color/white" />
        </androidx.constraintlayout.widget.ConstraintLayout>

        <!-- Album Art Section -->
        <com.google.android.material.card.MaterialCardView
            android:id="@+id/cardAlbumArt"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginHorizontal="20dp"
            android:layout_marginTop="30dp"
            app:cardCornerRadius="24dp"
            app:cardElevation="20dp">

            <androidx.constraintlayout.widget.ConstraintLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content">

                <ImageView
                    android:id="@+id/imgFullAlbumArt"
                    android:layout_width="match_parent"
                    android:layout_height="0dp"
                    android:scaleType="centerCrop"
                    android:src="@drawable/ic_launcher_background"
                    app:layout_constraintDimensionRatio="1:1"
                    app:layout_constraintTop_toTopOf="parent" />

                <!-- Premium Overlay if needed -->
                <View
                    android:id="@+id/premiumOverlay"
                    android:layout_width="match_parent"
                    android:layout_height="0dp"
                    android:background="#20000000"
                    android:visibility="gone"
                    app:layout_constraintBottom_toBottomOf="@+id/imgFullAlbumArt"
                    app:layout_constraintTop_toTopOf="@+id/imgFullAlbumArt" />
            </androidx.constraintlayout.widget.ConstraintLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- Info Section -->
        <androidx.constraintlayout.widget.ConstraintLayout
            android:id="@+id/infoLayout"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="30dp">

            <TextView
                android:id="@+id/textFullSongTitle"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:ellipsize="marquee"
                android:singleLine="true"
                android:text="Tên bài hát"
                android:textColor="@color/white"
                android:textSize="26sp"
                android:textStyle="bold"
                android:gravity="center"
                app:layout_constraintTop_toTopOf="parent" />

                app:layout_constraintTop_toBottomOf="@+id/textFullSongTitle" />

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:gravity="center"
                android:orientation="horizontal"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@+id/textFullSongTitle">

                <TextView
                    android:id="@+id/textFullArtistName"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:alpha="0.8"
                    android:text="Nghệ sĩ"
                    android:textColor="@color/white"
                    android:textSize="18sp" />

                <TextView
                    android:id="@+id/textSeparator"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:alpha="0.6"
                    android:paddingHorizontal="6dp"
                    android:text="•"
                    android:textColor="@color/white"
                    android:textSize="18sp" />

                <TextView
                    android:id="@+id/textFullGenre"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:alpha="0.8"
                    android:text="Thể loại"
                    android:textColor="@color/white"
                    android:textSize="18sp"
                    android:textStyle="bold" />
            </LinearLayout>

            <android.widget.Button
                android:id="@+id/btnBuySong"
                android:layout_width="wrap_content"
                android:layout_height="32dp"
                android:layout_marginTop="12dp"
                android:background="@drawable/bg_play_gradient"
                android:text="Gỡ bỏ giới hạn"
                android:textAllCaps="false"
                android:textColor="@color/white"
                android:textSize="12sp"
                android:textStyle="bold"
                android:visibility="gone"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@+id/textFullArtistName" />
        </androidx.constraintlayout.widget.ConstraintLayout>

        <!-- Progress & Time -->
        <SeekBar
            android:id="@+id/playerSeekBar"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="30dp"
            android:maxHeight="3dp"
            android:minHeight="3dp"
            android:paddingStart="12dp"
            android:paddingEnd="12dp"
            android:splitTrack="false"
            android:progressDrawable="@android:drawable/progress_horizontal"
            android:thumb="@drawable/custom_seekbar_thumb" />

        <androidx.constraintlayout.widget.ConstraintLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp"
            android:paddingHorizontal="12dp">

            <TextView
                android:id="@+id/textCurrentTime"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:alpha="0.8"
                android:text="0:00"
                android:textColor="#E0E0E0"
                android:textSize="12sp"
                android:textStyle="bold"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="parent" />

            <TextView
                android:id="@+id/textTotalTime"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:alpha="0.8"
                android:text="0:00"
                android:textColor="#E0E0E0"
                android:textSize="12sp"
                android:textStyle="bold"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintTop_toTopOf="parent" />
        </androidx.constraintlayout.widget.ConstraintLayout>

        <!-- Playback Controls -->
        <LinearLayout
            android:id="@+id/playerControls"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:weightSum="5"
            android:clipChildren="false"
            android:clipToPadding="false">

            <!-- Shuffle -->
            <FrameLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:gravity="center">
                <ImageButton
                    android:id="@+id/btnShuffle"
                    android:layout_width="48dp"
                    android:layout_height="48dp"
                    android:layout_gravity="center"
                    android:background="@drawable/bg_back_button_fixed"
                    android:padding="12dp"
                    android:src="@drawable/ic_shuffle_modern"
                    app:tint="@color/white" />
            </FrameLayout>

            <!-- Previous -->
            <FrameLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:gravity="center">
                <ImageButton
                    android:id="@+id/btnPrevious"
                    android:layout_width="54dp"
                    android:layout_height="54dp"
                    android:layout_gravity="center"
                    android:background="?attr/selectableItemBackgroundBorderless"
                    android:src="@android:drawable/ic_media_previous"
                    android:padding="8dp"
                    app:tint="@color/white" />
            </FrameLayout>

            <!-- Play/Pause with Pulse -->
            <FrameLayout
                android:layout_width="0dp"
                android:layout_height="110dp"
                android:layout_weight="1"
                android:clipChildren="false"
                android:clipToPadding="false">
                
                <View
                    android:id="@+id/viewPulseEffect"
                    android:layout_width="90dp"
                    android:layout_height="90dp"
                    android:layout_gravity="center"
                    android:alpha="0"
                    android:background="@drawable/bg_circle_white_transparent"
                    android:scaleX="1"
                    android:scaleY="1" />

                <com.google.android.material.floatingactionbutton.FloatingActionButton
                    android:id="@+id/btnPlayPause"
                    android:layout_width="80dp"
                    android:layout_height="80dp"
                    android:layout_gravity="center"
                    android:src="@android:drawable/ic_media_play"
                    app:backgroundTint="@color/white"
                    app:fabCustomSize="80dp"
                    app:maxImageSize="40dp"
                    app:tint="@color/black"
                    app:elevation="4dp"
                    app:useCompatPadding="false"
                    app:borderWidth="0dp" />
            </FrameLayout>

            <!-- Next -->
            <FrameLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:gravity="center">
                <ImageButton
                    android:id="@+id/btnNext"
                    android:layout_width="54dp"
                    android:layout_height="54dp"
                    android:layout_gravity="center"
                    android:background="?attr/selectableItemBackgroundBorderless"
                    android:src="@android:drawable/ic_media_next"
                    android:padding="8dp"
                    app:tint="@color/white" />
            </FrameLayout>

            <!-- Repeat -->
            <FrameLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:gravity="center">
                <ImageButton
                    android:id="@+id/btnRepeat"
                    android:layout_width="48dp"
                    android:layout_height="48dp"
                    android:layout_gravity="center"
                    android:background="@drawable/bg_back_button_fixed"
                    android:padding="12dp"
                    android:src="@drawable/ic_repeat_modern"
                    app:tint="@color/white" />
            </FrameLayout>

        </LinearLayout>

        <!-- Action Buttons Bar (Matching React Native UI) -->
        <LinearLayout
            android:id="@+id/extraActions"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="32dp"
            android:gravity="center"
            android:orientation="horizontal"
            android:background="@drawable/bg_glass_card"
            android:paddingVertical="12dp"
            android:paddingHorizontal="4dp">

            <ImageButton
                android:id="@+id/btnFavorite"
                android:layout_width="0dp"
                android:layout_height="44dp"
                android:layout_weight="1"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:padding="11dp"
                android:scaleType="fitCenter"
                android:src="@drawable/ic_heart_outline"
                app:tint="@color/white" />

            <ImageButton
                android:id="@+id/btnComments"
                android:layout_width="0dp"
                android:layout_height="44dp"
                android:layout_weight="1"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:padding="11dp"
                android:scaleType="fitCenter"
                android:src="@drawable/ic_comment"
                app:tint="@color/white" />

            <ImageButton
                android:id="@+id/btnLyrics"
                android:layout_width="0dp"
                android:layout_height="44dp"
                android:layout_weight="1"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:padding="11dp"
                android:scaleType="fitCenter"
                android:src="@drawable/ic_musical_notes"
                app:tint="@color/white" />

            <ImageButton
                android:id="@+id/btnSleepTimer"
                android:layout_width="0dp"
                android:layout_height="44dp"
                android:layout_weight="1"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:padding="11dp"
                android:scaleType="fitCenter"
                android:src="@android:drawable/ic_lock_idle_alarm"
                app:tint="@color/white" />

            <ImageButton
                android:id="@+id/btnAddToPlaylist"
                android:layout_width="0dp"
                android:layout_height="44dp"
                android:layout_weight="1"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:padding="11dp"
                android:scaleType="fitCenter"
                android:src="@drawable/ic_add"
                app:tint="@color/white" />

            <ImageButton
                android:id="@+id/btnDownload"
                android:layout_width="0dp"
                android:layout_height="44dp"
                android:layout_weight="1"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:padding="11dp"
                android:scaleType="fitCenter"
                android:src="@android:drawable/stat_sys_download"
                android:visibility="gone"
                app:tint="@color/white" />

            <ImageButton
                android:id="@+id/btnReport"
                android:layout_width="0dp"
                android:layout_height="44dp"
                android:layout_weight="1"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:padding="11dp"
                android:scaleType="fitCenter"
                android:src="@android:drawable/ic_menu_report_image"
                app:tint="@color/white" />
        </LinearLayout>

        <!-- Toggleable Content Sections -->
        <LinearLayout
            android:id="@+id/contentContainer"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="20dp"
            android:layout_marginBottom="40dp"
            android:orientation="vertical">

            <!-- Lyrics Section -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/lyricsCard"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:visibility="gone"
                app:cardBackgroundColor="@android:color/transparent"
                app:cardCornerRadius="24dp"
                app:cardElevation="0dp">

                <LinearLayout
                    android:id="@+id/lyricsContainer"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:background="@drawable/bg_lyrics_card"
                    android:orientation="vertical"
                    android:padding="28dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Lời bài hát"
                        android:textColor="@color/white"
                        android:textSize="22sp"
                        android:textStyle="bold" />

                    <TextView
                        android:id="@+id/textLyrics"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="20dp"
                        android:lineSpacingExtra="10dp"
                        android:text="Hệ thống đang tải lời bài hát cho bạn..."
                        android:textColor="#F0F0F0"
                        android:textSize="20sp"
                        android:textStyle="bold" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- Comments Section -->
            <LinearLayout
                android:id="@+id/commentsContainer"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:visibility="gone"
                android:layout_marginTop="16dp"
                android:background="@drawable/bg_lyrics_card"
                android:padding="20dp">

                <TextView
                    android:id="@+id/txtCommentHeader"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Bình luận"
                    android:textColor="@color/white"
                    android:textSize="22sp"
                    android:textStyle="bold"
                    android:layout_marginBottom="10dp" />

                <androidx.recyclerview.widget.RecyclerView
                    android:id="@+id/rvComments"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:nestedScrollingEnabled="false"
                    android:visibility="visible" />

                <TextView
                    android:id="@+id/txtNoComments"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Chưa có bình luận nào.\nHãy là người đầu tiên!"
                    android:gravity="center"
                    android:textColor="#AAAAAA"
                    android:textSize="14sp"
                    android:padding="20dp"
                    android:visibility="gone" />

                <LinearLayout
                    android:id="@+id/ratingStarContainer"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_gravity="center_horizontal"
                    android:layout_marginTop="16dp">

                    <ImageView
                        android:id="@+id/star1"
                        android:layout_width="32dp"
                        android:layout_height="32dp"
                        android:src="@drawable/ic_star"
                        android:padding="4dp" />
                    <ImageView
                        android:id="@+id/star2"
                        android:layout_width="32dp"
                        android:layout_height="32dp"
                        android:src="@drawable/ic_star"
                        android:padding="4dp" />
                    <ImageView
                        android:id="@+id/star3"
                        android:layout_width="32dp"
                        android:layout_height="32dp"
                        android:src="@drawable/ic_star"
                        android:padding="4dp" />
                    <ImageView
                        android:id="@+id/star4"
                        android:layout_width="32dp"
                        android:layout_height="32dp"
                        android:src="@drawable/ic_star"
                        android:padding="4dp" />
                    <ImageView
                        android:id="@+id/star5"
                        android:layout_width="32dp"
                        android:layout_height="32dp"
                        android:src="@drawable/ic_star"
                        android:padding="4dp" />
                </LinearLayout>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_marginTop="12dp"
                    android:gravity="center_vertical">

                    <EditText
                        android:id="@+id/editComment"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:hint="Viết bình luận..."
                        android:textColor="@color/white"
                        android:textColorHint="#AAA"
                        android:background="@drawable/glass_circle_bg"
                        android:paddingHorizontal="15dp"
                        android:paddingVertical="8dp"/>

                    <ImageButton
                        android:id="@+id/btnSendComment"
                        android:layout_width="44dp"
                        android:layout_height="44dp"
                        android:background="?attr/selectableItemBackgroundBorderless"
                        android:src="@android:drawable/ic_menu_send"
                        app:tint="@color/white" />
                </LinearLayout>
            </LinearLayout>

            <!-- Queue Section -->
            <LinearLayout
                android:id="@+id/queueContainer"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:visibility="visible"
                android:layout_marginTop="16dp"
                android:background="@drawable/bg_lyrics_card"
                android:padding="20dp">

                <LinearLayout
                    android:id="@+id/tabQueueContainer"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center"
                    android:background="@drawable/bg_glass_card"
                    android:padding="4dp"
                    android:layout_marginBottom="16dp">

                    <TextView
                        android:id="@+id/btnTabQueue"
                        android:layout_width="0dp"
                        android:layout_height="36dp"
                        android:layout_weight="1"
                        android:text="Tiếp theo"
                        android:textColor="@color/white"
                        android:textSize="14sp"
                        android:textStyle="bold"
                        android:gravity="center"
                        android:background="@drawable/bg_tab_purple"
                        android:clickable="true"
                        android:focusable="true" />

                    <TextView
                        android:id="@+id/btnTabRelated"
                        android:layout_width="0dp"
                        android:layout_height="36dp"
                        android:layout_weight="1"
                        android:text="Gợi ý"
                        android:textColor="@color/textSecondary"
                        android:textSize="14sp"
                        android:textStyle="bold"
                        android:gravity="center"
                        android:clickable="true"
                        android:focusable="true"/>
                </LinearLayout>

                <ProgressBar
                    android:id="@+id/pbQueue"
                    android:layout_width="32dp"
                    android:layout_height="32dp"
                    android:layout_gravity="center"
                    android:visibility="gone"
                    android:layout_margin="20dp"/>

                <androidx.recyclerview.widget.RecyclerView
                    android:id="@+id/rvQueue"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:nestedScrollingEnabled="false" />
            </LinearLayout>

        </LinearLayout>

    </LinearLayout>
</androidx.core.widget.NestedScrollView>
