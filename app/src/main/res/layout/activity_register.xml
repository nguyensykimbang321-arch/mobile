<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#121212"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="24dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:text="Đăng ký"
            android:textColor="#FFFFFF"
            android:textSize="32sp"
            android:textStyle="bold" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:layout_marginTop="8dp"
            android:text="Tạo tài khoản mới"
            android:textColor="#B3FFFFFF"
            android:textSize="16sp" />

        <EditText
            android:id="@+id/editTextUsername"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="32dp"
            android:background="#2A2A2A"
            android:hint="Tên đăng nhập *"
            android:padding="16dp"
            android:textColor="#FFFFFF"
            android:textColorHint="#B3FFFFFF" />

        <EditText
            android:id="@+id/editTextEmail"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:background="#2A2A2A"
            android:hint="Email *"
            android:inputType="textEmailAddress"
            android:padding="16dp"
            android:textColor="#FFFFFF"
            android:textColorHint="#B3FFFFFF" />

        <EditText
            android:id="@+id/editTextFullName"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:background="#2A2A2A"
            android:hint="Họ và tên"
            android:padding="16dp"
            android:textColor="#FFFFFF"
            android:textColorHint="#B3FFFFFF" />

        <EditText
            android:id="@+id/editTextPassword"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:background="#2A2A2A"
            android:hint="Mật khẩu *"
            android:inputType="textPassword"
            android:padding="16dp"
            android:textColor="#FFFFFF"
            android:textColorHint="#B3FFFFFF" />

        <CheckBox
            android:id="@+id/checkBoxArtist"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="20dp"
            android:text="Đăng ký làm nghệ sĩ"
            android:textColor="#FFFFFF"
            android:buttonTint="#FFFFFF" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginStart="32dp"
            android:text="Tài khoản sẽ được chuyển cho admin duyệt trước khi hoạt động."
            android:textColor="#B3FFFFFF"
            android:textSize="12sp" />

        <LinearLayout
            android:id="@+id/layoutArtistFields"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:orientation="vertical"
            android:visibility="gone">

            <EditText
                android:id="@+id/editTextCountry"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="#2A2A2A"
                android:hint="Quốc gia (VD: Việt Nam)"
                android:padding="16dp"
                android:textColor="#FFFFFF"
                android:textColorHint="#B3FFFFFF" />

            <EditText
                android:id="@+id/editTextBio"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:background="#2A2A2A"
                android:gravity="top"
                android:hint="Giới thiệu / tiểu sử"
                android:minLines="3"
                android:padding="16dp"
                android:textColor="#FFFFFF"
                android:textColorHint="#B3FFFFFF" />

            <EditText
                android:id="@+id/editTextArtistImage"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:background="#2A2A2A"
                android:hint="URL Ảnh đại diện nghệ sĩ"
                android:padding="16dp"
                android:textColor="#FFFFFF"
                android:textColorHint="#B3FFFFFF" />
        </LinearLayout>

        <Button
            android:id="@+id/buttonRegister"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="32dp"
            android:backgroundTint="#FFFFFF"
            android:padding="16dp"
            android:text="Đăng ký"
            android:textColor="#121212"
            android:textStyle="bold" />

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:layout_marginTop="24dp"
            android:orientation="horizontal">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Đã có tài khoản? "
                android:textColor="#B3FFFFFF" />

            <TextView
                android:id="@+id/textViewLogin"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Đăng nhập ngay"
                android:textColor="#FFFFFF"
                android:textStyle="bold" />
        </LinearLayout>
    </LinearLayout>
</ScrollView>
