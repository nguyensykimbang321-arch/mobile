<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#050505"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingBottom="100dp">

        <!-- Header Section -->
        <FrameLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/bg_profile_header"
            android:layout_marginHorizontal="0dp"
            android:layout_marginTop="-40dp"
            android:paddingTop="80dp"
            android:paddingBottom="30dp"
            android:paddingHorizontal="24dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical">

                <!-- Profile Info -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:paddingBottom="28dp">

                    <!-- Avatar Wrapper -->
                    <RelativeLayout
                        android:layout_width="100dp"
                        android:layout_height="100dp">
                        <!-- Outer Glow/Stroke -->
                        <View
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:background="@drawable/circle_button_bg"
                            android:backgroundTint="#1AFFFFFF"
                            android:layout_margin="0dp"/>
                        
                        <com.google.android.material.imageview.ShapeableImageView
                            android:id="@+id/imgProfileAvatar"
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:padding="4dp"
                            app:shapeAppearanceOverlay="@style/CircleImage"
                            android:background="@drawable/circle_button_bg"
                            android:backgroundTint="#8B5CF6"
                            android:src="@drawable/ic_launcher_background"
                            android:scaleType="centerCrop"
                            android:elevation="4dp"/>
                        
                         <!-- Premium Star Icon -->
                         <ImageView
                             android:id="@+id/imgPremiumCrown"
                             android:layout_width="28dp"
                             android:layout_height="28dp"
                             android:layout_alignParentBottom="true"
                             android:layout_alignParentEnd="true"
                             android:background="@drawable/circle_button_bg"
                             android:backgroundTint="#F59E0B"
                             android:padding="6dp"
                             android:src="@android:drawable/btn_star_big_on"
                             app:tint="#FFF"
                             android:elevation="6dp"
                             android:visibility="gone"/>
                    </RelativeLayout>

                    <!-- Name & Role -->
                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:layout_marginStart="20dp"
                        android:orientation="vertical">

                        <TextView
                            android:id="@+id/txtProfileName"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Username"
                            android:textColor="#FFFFFF"
                            android:textSize="22sp"
                            android:fontFamily="sans-serif-medium"
                            android:textStyle="bold"
                            android:ellipsize="end"
                            android:maxLines="1"/>

                        <LinearLayout
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="8dp"
                            android:orientation="horizontal"
                            android:gravity="center_vertical">

                            <!-- Role Badge -->
                            <TextView
                                android:id="@+id/txtRoleBadge"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:background="@drawable/bg_stat_card"
                                android:paddingHorizontal="10dp"
                                android:paddingVertical="3dp"
                                android:text="USER"
                                android:textColor="#3B82F6"
                                android:textSize="10sp"
                                android:textStyle="bold"
                                android:layout_marginEnd="10dp"
                                android:letterSpacing="0.1"/>

                            <TextView
                                android:id="@+id/txtProfileEmail"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="email@example.com"
                                android:textColor="#AAAAAA"
                                android:textSize="13sp"
                                android:letterSpacing="0.02"/>
                        </LinearLayout>
                    </LinearLayout>
                </LinearLayout>

                <!-- Stats Bar -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center">

                    <!-- Following Stat -->
                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:background="@drawable/bg_stat_card"
                        android:paddingVertical="18dp"
                        android:layout_marginEnd="8dp"
                        android:gravity="center"
                        android:orientation="vertical">
                        <TextView
                            android:id="@+id/txtStatFollowing"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="0"
                            android:textColor="#FFFFFF"
                            android:textStyle="bold"
                            android:textSize="18sp"
                            android:letterSpacing="0.05"/>
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="THEO DÕI"
                            android:textColor="#888888"
                            android:textSize="9sp"
                            android:layout_marginTop="4dp"
                            android:textStyle="bold"
                            android:alpha="0.8"/>
                    </LinearLayout>

                    <!-- Followers Stat -->
                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:background="@drawable/bg_stat_card"
                        android:paddingVertical="18dp"
                        android:layout_marginHorizontal="4dp"
                        android:gravity="center"
                        android:orientation="vertical">
                        <TextView
                            android:id="@+id/txtStatFollowers"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="0"
                            android:textColor="#FFFFFF"
                            android:textStyle="bold"
                            android:textSize="18sp"
                            android:letterSpacing="0.05"/>
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="FOLLOWERS"
                            android:textColor="#888888"
                            android:textSize="9sp"
                            android:layout_marginTop="4dp"
                            android:textStyle="bold"
                            android:alpha="0.8"/>
                    </LinearLayout>

                    <!-- Playlists Stat -->
                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:background="@drawable/bg_stat_card"
                        android:paddingVertical="18dp"
                        android:layout_marginStart="8dp"
                        android:gravity="center"
                        android:orientation="vertical">
                        <TextView
                            android:id="@+id/txtStatPlaylists"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="0"
                            android:textColor="#FFFFFF"
                            android:textStyle="bold"
                            android:textSize="18sp"
                            android:letterSpacing="0.05"/>
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="PLAYLISTS"
                            android:textColor="#888888"
                            android:textSize="9sp"
                            android:layout_marginTop="4dp"
                            android:textStyle="bold"
                            android:alpha="0.8"/>
                    </LinearLayout>
                </LinearLayout>
            </LinearLayout>
        </FrameLayout>

        <!-- Tabs Section -->
        <com.google.android.material.tabs.TabLayout
            android:id="@+id/tabLayoutProfile"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@android:color/transparent"
            app:tabIndicatorColor="@color/vibrant_purple"
            app:tabSelectedTextColor="@color/white"
            app:tabTextColor="#888888"
            app:tabIndicatorHeight="3dp"
            app:tabRippleColor="@android:color/transparent"
            android:layout_marginTop="16dp"
            android:layout_marginHorizontal="20dp"
            app:tabMode="fixed">
            <com.google.android.material.tabs.TabItem
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Cài đặt" />
            <com.google.android.material.tabs.TabItem
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Tải xuống" />
        </com.google.android.material.tabs.TabLayout>

        <!-- Container for switching -->
        <FrameLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content">

            <!-- Menu Container -->
            <LinearLayout
                android:id="@+id/layoutProfileMenu"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:paddingHorizontal="20dp"
                android:paddingTop="24dp">

            <!-- Section 1: Cá nhân -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="CÁ NHÂN"
                android:textColor="#888888"
                android:textSize="12sp"
                android:textStyle="bold"
                android:layout_marginBottom="12dp"
                android:layout_marginStart="4dp"/>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="@drawable/bg_glass_card"
                android:layout_marginBottom="20dp">

                <!-- Edit Profile -->
                <LinearLayout
                    android:id="@+id/btnEditProfile"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:padding="16dp"
                    android:clickable="true"
                    android:focusable="true"
                    android:background="?attr/selectableItemBackground">
                    <ImageView
                        android:layout_width="44dp"
                        android:layout_height="44dp"
                        android:background="@drawable/circle_button_bg"
                        android:backgroundTint="#3B82F6"
                        android:padding="12dp"
                        android:src="@drawable/ic_nav_profile"
                        app:tint="#FFF"/>
                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:layout_marginStart="16dp"
                        android:orientation="vertical">
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Chỉnh sửa hồ sơ"
                            android:textColor="#FFF"
                            android:textStyle="bold"
                            android:textSize="15sp"/>
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Thông tin cá nhân &amp; hình đại diện"
                            android:textColor="#888888"
                            android:textSize="12sp"
                            android:layout_marginTop="2dp"/>
                    </LinearLayout>
                    <ImageView
                        android:layout_width="20dp"
                        android:layout_height="20dp"
                        android:src="@drawable/ic_chevron_right"
                        app:tint="#888888"/>
                </LinearLayout>

                <View android:layout_width="match_parent" android:layout_height="1dp" android:background="#1AFFFFFF" android:layout_marginHorizontal="16dp"/>

                <!-- Settings (Change Password) -->
                <LinearLayout
                    android:id="@+id/btnSettings"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:padding="16dp"
                    android:clickable="true"
                    android:focusable="true"
                    android:background="?attr/selectableItemBackground">
                    <ImageView
                        android:layout_width="44dp"
                        android:layout_height="44dp"
                        android:background="@drawable/circle_button_bg"
                        android:backgroundTint="#8B5CF6"
                        android:padding="11dp"
                        android:src="@drawable/ic_nav_library"
                        app:tint="#FFF"/>
                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:layout_marginStart="16dp"
                        android:orientation="vertical">
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Đổi mật khẩu"
                            android:textColor="#FFF"
                            android:textStyle="bold"
                            android:textSize="15sp"/>
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Bảo mật &amp; quyền riêng tư"
                            android:textColor="#888888"
                            android:textSize="12sp"
                            android:layout_marginTop="2dp"/>
                    </LinearLayout>
                    <ImageView
                        android:layout_width="20dp"
                        android:layout_height="20dp"
                        android:src="@drawable/ic_chevron_right"
                        app:tint="#888888"/>
                </LinearLayout>
            </LinearLayout>


            <!-- Section 2: Tài chính -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="TÀI CHÍNH &amp; ƯU ĐÃI"
                android:textColor="#888888"
                android:textSize="12sp"
                android:textStyle="bold"
                android:layout_marginBottom="12dp"
                android:layout_marginStart="4dp"/>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="@drawable/bg_glass_card"
                android:layout_marginBottom="20dp">

                <!-- Wallet -->
                <LinearLayout
                    android:id="@+id/btnWallet"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:padding="16dp"
                    android:clickable="true"
                    android:focusable="true"
                    android:background="?attr/selectableItemBackground">
                    <ImageView
                        android:layout_width="44dp"
                        android:layout_height="44dp"
                        android:background="@drawable/circle_button_bg"
                        android:backgroundTint="#10B981"
                        android:padding="10dp"
                        android:src="@android:drawable/ic_menu_rotate"
                        app:tint="#FFF"/>
                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:layout_marginStart="16dp"
                        android:orientation="vertical">
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Ví của tôi"
                            android:textColor="#FFF"
                            android:textStyle="bold"
                            android:textSize="15sp"/>
                        <TextView
                            android:id="@+id/txtBalanceSubtitle"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Quản lý số dư: 0đ"
                            android:textColor="#888888"
                            android:textSize="12sp"
                            android:layout_marginTop="2dp"/>
                    </LinearLayout>
                    <ImageView style="@style/ChevronIcon"/>
                </LinearLayout>

                <View android:layout_width="match_parent" android:layout_height="1dp" android:background="#1AFFFFFF" android:layout_marginHorizontal="16dp"/>

                <!-- Premium -->
                <LinearLayout
                    android:id="@+id/btnPremium"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:padding="16dp"
                    android:clickable="true"
                    android:focusable="true"
                    android:background="?attr/selectableItemBackground">
                    <ImageView
                        android:layout_width="44dp"
                        android:layout_height="44dp"
                        android:background="@drawable/circle_button_bg"
                        android:backgroundTint="#F59E0B"
                        android:padding="11dp"
                        android:src="@drawable/ic_star_badge"
                        app:tint="#FFF"/>
                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:layout_marginStart="16dp"
                        android:orientation="vertical">
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Gói Premium"
                            android:textColor="#FFF"
                            android:textStyle="bold"
                            android:textSize="15sp"/>
                        <TextView
                            android:id="@+id/txtPremiumSubtitle"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Nâng cấp trải nghiệm âm nhạc"
                            android:textColor="#888888"
                            android:textSize="12sp"
                            android:layout_marginTop="2dp"/>
                    </LinearLayout>
                    <ImageView
                        android:layout_width="20dp"
                        android:layout_height="20dp"
                        android:src="@drawable/ic_chevron_right"
                        app:tint="#888888"/>
                </LinearLayout>

                <View android:layout_width="match_parent" android:layout_height="1dp" android:background="#1AFFFFFF" android:layout_marginHorizontal="16dp"/>

                <!-- Membership History -->
                <LinearLayout
                    android:id="@+id/btnMembershipHistory"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:padding="16dp"
                    android:clickable="true"
                    android:focusable="true"
                    android:background="?attr/selectableItemBackground">
                    <ImageView
                        android:layout_width="44dp"
                        android:layout_height="44dp"
                        android:background="@drawable/circle_button_bg"
                        android:backgroundTint="#8B5CF6"
                        android:padding="10dp"
                        android:src="@drawable/ic_star"
                        app:tint="#FFF"/>
                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:layout_marginStart="16dp"
                        android:orientation="vertical">
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Hội viên của tôi"
                            android:textColor="#FFF"
                            android:textStyle="bold"
                            android:textSize="15sp"/>
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Quản lý các gói Hội viên"
                            android:textColor="#888888"
                            android:textSize="12sp"
                            android:layout_marginTop="2dp"/>
                    </LinearLayout>
                    <ImageView
                        android:layout_width="20dp"
                        android:layout_height="20dp"
                        android:src="@drawable/ic_chevron_right"
                        app:tint="#888888"/>
                </LinearLayout>
            </LinearLayout>

            <!-- Section 3: Bảng điều khiển -->
            <TextView
                android:id="@+id/lblDashboard"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="BẢNG ĐIỀU KHIỂN"
                android:textColor="#888888"
                android:textSize="12sp"
                android:textStyle="bold"
                android:layout_marginBottom="12dp"
                android:layout_marginStart="4dp"/>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="@drawable/bg_glass_card"
                android:layout_marginBottom="20dp">

                <!-- Artist Dashboard -->
                <LinearLayout
                    android:id="@+id/btnArtistDashboard"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:padding="16dp"
                    android:clickable="true"
                    android:focusable="true"
                    android:background="?attr/selectableItemBackground"
                    android:visibility="gone">
                    <ImageView
                        android:layout_width="44dp"
                        android:layout_height="44dp"
                        android:background="@drawable/circle_button_bg"
                        android:backgroundTint="#EC4899"
                        android:padding="10dp"
                        android:src="@android:drawable/ic_menu_sort_by_size"
                        app:tint="#FFF"/>
                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:layout_marginStart="16dp"
                        android:orientation="vertical">
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Artist Dashboard"
                            android:textColor="#FFF"
                            android:textStyle="bold"
                            android:textSize="15sp"/>
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Thống kê doanh thu &amp; bài hát"
                            android:textColor="#888888"
                            android:textSize="12sp"
                            android:layout_marginTop="2dp"/>
                    </LinearLayout>
                    <ImageView style="@style/ChevronIcon"/>
                </LinearLayout>

                <View 
                    android:id="@+id/sepApplyArtist"
                    android:layout_width="match_parent" 
                    android:layout_height="1dp" 
                    android:background="#1AFFFFFF" 
                    android:layout_marginHorizontal="16dp"
                    android:visibility="gone"/>

                <!-- Apply Artist -->
                <LinearLayout
                    android:id="@+id/btnApplyArtist"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:padding="16dp"
                    android:clickable="true"
                    android:focusable="true"
                    android:background="?attr/selectableItemBackground"
                    android:visibility="gone">
                    <ImageView
                        android:layout_width="44dp"
                        android:layout_height="44dp"
                        android:background="@drawable/circle_button_bg"
                        android:backgroundTint="#8B5CF6"
                        android:padding="10dp"
                        android:src="@android:drawable/btn_star_big_on"
                        app:tint="#FFF"/>
                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:layout_marginStart="16dp"
                        android:orientation="vertical">
                        <TextView
                            android:id="@+id/txtApplyArtistTitle"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Trở thành Nghệ sĩ"
                            android:textColor="#FFF"
                            android:textStyle="bold"
                            android:textSize="15sp"/>
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Bắt đầu chia sẻ âm nhạc của bạn"
                            android:textColor="#888888"
                            android:textSize="12sp"
                            android:layout_marginTop="2dp"/>
                    </LinearLayout>
                    <ImageView style="@style/ChevronIcon"/>
                </LinearLayout>

                <View 
                    android:id="@+id/sepArtist"
                    android:layout_width="match_parent" 
                    android:layout_height="1dp" 
                    android:background="#1AFFFFFF" 
                    android:layout_marginHorizontal="16dp"
                    android:visibility="gone"/>

                <!-- Admin Dashboard -->
                <LinearLayout
                    android:id="@+id/btnAdminDashboard"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:padding="16dp"
                    android:clickable="true"
                    android:focusable="true"
                    android:background="?attr/selectableItemBackground"
                    android:visibility="gone">
                    <ImageView
                        android:layout_width="44dp"
                        android:layout_height="44dp"
                        android:background="@drawable/circle_button_bg"
                        android:backgroundTint="#EF4444"
                        android:padding="10dp"
                        android:src="@android:drawable/ic_menu_manage"
                        app:tint="#FFF"/>
                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:layout_marginStart="16dp"
                        android:orientation="vertical">
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Quản trị hệ thống"
                            android:textColor="#FFF"
                            android:textStyle="bold"
                            android:textSize="15sp"/>
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Quản lý người dùng &amp; hệ thống"
                            android:textColor="#888888"
                            android:textSize="12sp"
                            android:layout_marginTop="2dp"/>
                    </LinearLayout>
                    <ImageView style="@style/ChevronIcon"/>
                </LinearLayout>

                <!-- Help -->
                <LinearLayout
                    android:id="@+id/btnHelp"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:padding="16dp"
                    android:clickable="true"
                    android:focusable="true"
                    android:background="?attr/selectableItemBackground">
                    <ImageView
                        android:layout_width="44dp"
                        android:layout_height="44dp"
                        android:background="@drawable/circle_button_bg"
                        android:backgroundTint="#F59E0B"
                        android:padding="10dp"
                        android:src="@android:drawable/ic_menu_help"
                        app:tint="#FFF"/>
                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:layout_marginStart="16dp"
                        android:orientation="vertical">
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Trợ giúp &amp; Hỗ trợ"
                            android:textColor="#FFF"
                            android:textStyle="bold"
                            android:textSize="15sp"/>
                    </LinearLayout>
                    <ImageView style="@style/ChevronIcon"/>
                </LinearLayout>
            </LinearLayout>

            <!-- Logout -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="@drawable/bg_glass_card"
                android:layout_marginTop="8dp"
                android:layout_marginBottom="40dp">

                <LinearLayout
                    android:id="@+id/btnLogout"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:padding="16dp"
                    android:clickable="true"
                    android:focusable="true"
                    android:background="?attr/selectableItemBackground">
                    <ImageView
                        android:layout_width="44dp"
                        android:layout_height="44dp"
                        android:background="@drawable/circle_button_bg"
                        android:backgroundTint="#6B7280"
                        android:padding="10dp"
                        android:src="@android:drawable/ic_lock_power_off"
                        app:tint="#FFF"/>
                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:layout_marginStart="16dp"
                        android:orientation="vertical">
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Đăng xuất"
                            android:textColor="#EF4444"
                            android:textStyle="bold"
                            android:textSize="15sp"/>
                    </LinearLayout>
                    <ImageView style="@style/ChevronIcon"/>
                </LinearLayout>
            </LinearLayout>
        </LinearLayout>

        <!-- Downloads Container -->
        <LinearLayout
            android:id="@+id/layoutDownloads"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingHorizontal="20dp"
            android:paddingTop="24dp"
            android:visibility="gone">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="BÀI HÁT ĐÃ TẢI"
                android:textColor="#888888"
                android:textSize="12sp"
                android:textStyle="bold"
                android:layout_marginBottom="12dp"
                android:layout_marginStart="4dp"/>
            
            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/rvDownloads"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:nestedScrollingEnabled="false"
                android:background="@drawable/bg_glass_card"
                android:padding="8dp"/>

            <LinearLayout
                android:id="@+id/layoutDownloadsEmpty"
                android:layout_width="match_parent"
                android:layout_height="200dp"
                android:gravity="center"
                android:orientation="vertical"
                android:visibility="gone">
                <ImageView
                    android:layout_width="64dp"
                    android:layout_height="64dp"
                    android:src="@android:drawable/stat_sys_download_done"
                    app:tint="#33FFFFFF"/>
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="16dp"
                    android:text="Chưa có bài hát nào được tải"
                    android:textColor="#888888"/>
            </LinearLayout>
        </LinearLayout>
    </FrameLayout>

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Music App Version 1.2.0 • Made with ❤️"
        android:textColor="#666"
        android:textSize="12sp"
        android:layout_marginTop="20dp"
        android:layout_marginBottom="24dp"
        android:gravity="center_horizontal"/>

</LinearLayout>
</androidx.core.widget.NestedScrollView>
