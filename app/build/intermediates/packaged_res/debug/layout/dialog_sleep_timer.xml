<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    app:cardBackgroundColor="#1E1E1E"
    app:cardCornerRadius="28dp"
    app:cardElevation="24dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="28dp">

        <TextView
            android:id="@+id/dialogTitle"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Hẹn giờ tắt nhạc"
            android:textColor="@android:color/white"
            android:textSize="22sp"
            android:textStyle="bold"
            android:gravity="center"
            android:layout_marginBottom="20dp" />

        <!-- Status Container (Visible when Timer Active) -->
        <LinearLayout
            android:id="@+id/activeTimerContainer"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:background="@drawable/bg_timer_status_active"
            android:padding="20dp"
            android:layout_marginBottom="24dp"
            android:gravity="center_vertical"
            android:visibility="gone">

            <FrameLayout
                android:layout_width="60dp"
                android:layout_height="60dp"
                android:background="@drawable/circle_timer_icon_bg">
                <ImageView
                    android:id="@+id/timerIcon"
                    android:layout_width="32dp"
                    android:layout_height="32dp"
                    android:layout_gravity="center"
                    android:src="@android:drawable/ic_lock_idle_alarm"
                    app:tint="#F59E0B" />
            </FrameLayout>
            
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:layout_marginStart="16dp">
                
                <TextView
                    android:id="@+id/timerStatusTitle"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Nhạc sẽ tắt lúc"
                    android:textColor="#FDE68A"
                    android:textSize="14sp"
                    android:textStyle="bold" />
                    
                <TextView
                    android:id="@+id/textTargetTime"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="22:30"
                    android:textColor="@android:color/white"
                    android:textSize="24sp"
                    android:textStyle="bold" />
                    
                 <TextView
                    android:id="@+id/textRemainingTime"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="(Còn khoảng 30 phút)"
                    android:textColor="#9CA3AF"
                    android:textSize="13sp" />
            </LinearLayout>
        </LinearLayout>
        
        <!-- Infinite Play Status (Visible when Infinite Active) -->
         <LinearLayout
            android:id="@+id/infiniteStatusContainer"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:background="@drawable/bg_timer_status_infinite"
            android:padding="20dp"
            android:layout_marginBottom="24dp"
            android:gravity="center_vertical"
            android:visibility="gone">

            <FrameLayout
                android:layout_width="60dp"
                android:layout_height="60dp"
                android:background="@drawable/circle_infinite_icon_bg">
                <ImageView
                    android:layout_width="32dp"
                    android:layout_height="32dp"
                    android:layout_gravity="center"
                    android:src="@drawable/ic_all_inclusive" 
                    app:tint="#8B5CF6" /> 
                    <!-- Note: Need vector for infinite, or use text "∞" -->
            </FrameLayout>
            
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:layout_marginStart="16dp">
                
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Chế độ dừng sau bài này"
                    android:textColor="#C4B5FD"
                    android:textSize="14sp"
                    android:textStyle="bold" />
                    
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Nhạc sẽ tắt khi hết bài hát hiện tại."
                    android:textColor="#9CA3AF"
                    android:textSize="13sp" />
            </LinearLayout>
        </LinearLayout>

        <!-- No Timer Text -->
        <TextView
            android:id="@+id/textNoTimer"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Chưa hẹn giờ"
            android:textColor="#9CA3AF"
            android:textSize="16sp"
            android:gravity="center"
            android:layout_marginBottom="24dp"
            android:fontFamily="sans-serif-medium"
            android:textStyle="italic" 
            android:visibility="visible"/>

        <!-- Slider Section -->
        <LinearLayout
            android:id="@+id/sliderSection"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="center"
            android:layout_marginBottom="24dp">
            
            <TextView
                android:id="@+id/textSliderValue"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="30 phút"
                android:textColor="@android:color/white"
                android:textSize="28sp"
                android:textStyle="bold"
                android:layout_marginBottom="16dp" />

            <SeekBar
                android:id="@+id/timerSeekBar"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:max="300"
                android:progress="30"
                android:progressTint="#F59E0B"
                android:thumbTint="#F59E0B"
                android:paddingStart="0dp"
                android:paddingEnd="0dp"
                android:minHeight="10dp"
                android:layout_marginBottom="8dp"/>
                
            <!-- Ruler -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal">
                <!-- 0h (1 phút) -->
                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="1m"
                    android:textSize="10sp"
                    android:textColor="#9CA3AF"
                    android:gravity="left"/>
                 <!-- 1h (60m) -->
                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="1h"
                    android:textSize="10sp"
                    android:textColor="#9CA3AF"
                    android:gravity="center"/>
                <!-- 2h (120m) -->
                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="2h"
                    android:textSize="10sp"
                    android:textColor="#9CA3AF"
                    android:gravity="center"/>
                <!-- 3h (180m) -->
                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="3h"
                    android:textSize="10sp"
                    android:textColor="#9CA3AF"
                    android:gravity="center"/>
                 <!-- 4h (240m) -->
                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="4h"
                    android:textSize="10sp"
                    android:textColor="#9CA3AF"
                    android:gravity="center"/>
                 <!-- 5h (300m) -->
                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="5h"
                    android:textSize="10sp"
                    android:textColor="#9CA3AF"
                    android:gravity="right"/>
            </LinearLayout>
        </LinearLayout>

        <!-- Actions -->
        <Button
            android:id="@+id/btnSetTimer"
            android:layout_width="match_parent"
            android:layout_height="50dp"
            android:text="Bắt đầu hẹn giờ"
            android:background="@drawable/bg_button_gradient_orange"
            android:textColor="@android:color/black"
            android:textStyle="bold"
            android:textSize="16sp"
            android:layout_marginBottom="16dp"
            app:backgroundTint="@null" />
            
        <Button
            android:id="@+id/btnCancelTimer"
            android:layout_width="match_parent"
            android:layout_height="50dp"
            android:text="Hủy hẹn giờ"
            android:background="@drawable/bg_button_cancel_red"
            android:textColor="#EF4444"
            android:textStyle="bold"
            android:textSize="16sp"
            android:visibility="gone"
            android:layout_marginBottom="16dp"
            app:backgroundTint="@null" />

        <Button
            android:id="@+id/btnEndSongPlay"
            android:layout_width="match_parent"
            android:layout_height="50dp"
            android:text="Nghe hết bài sẽ tắt"
            android:background="@drawable/bg_button_outline_white"
            android:textColor="#9CA3AF"
            android:textStyle="bold"
            android:textSize="16sp"
            android:layout_marginBottom="16dp"
            android:drawableStart="@android:drawable/ic_menu_recent_history" 
            android:drawablePadding="8dp"
            android:gravity="center"
            app:backgroundTint="@null" />

        <TextView
            android:id="@+id/btnCloseDialog"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Đóng"
            android:textColor="#9CA3AF"
            android:textSize="16sp"
            android:textStyle="bold"
            android:gravity="center"
            android:padding="12dp"
            android:background="?attr/selectableItemBackground" />

    </LinearLayout>
</androidx.cardview.widget.CardView>
