<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/miniPlayerContainer"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginHorizontal="10dp"
    android:layout_marginBottom="12dp"
    android:clipChildren="false"
    android:clipToPadding="false">

    <!-- EXPANDED STATE -->
    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/miniPlayerExpanded"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@drawable/bg_mini_player"
        android:clickable="true"
        android:focusable="true"
        android:elevation="10dp"
        android:paddingStart="16dp"
        android:paddingEnd="18dp"
        android:paddingTop="12dp"
        android:paddingBottom="12dp"
        android:clipChildren="false"
        android:clipToPadding="false">

        <ImageView
            android:id="@+id/premiumGlow"
            android:layout_width="0dp"
            android:layout_height="0dp"
            android:layout_margin="-4dp"
            android:alpha="0.9"
            android:background="@drawable/bg_mini_player_premium"
            android:visibility="gone"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent" />

        <!-- Close & Collapse Buttons -->
        <LinearLayout
            android:id="@+id/actionsRight"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:gravity="center"
            android:orientation="vertical"
            android:translationY="-8dp"
            android:elevation="12dp"
            android:layout_marginEnd="0dp"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toTopOf="parent">

            <ImageButton
                android:id="@+id/btnMiniClose"
                android:layout_width="26dp"
                android:layout_height="26dp"
                android:layout_marginTop="8dp"
                android:layout_marginBottom="12dp"
                android:background="@drawable/bg_mini_close_button"
                android:padding="5dp"
                android:scaleType="centerInside"
                android:src="@android:drawable/ic_menu_close_clear_cancel"
                app:tint="#6b7280" />

            <ImageButton
                android:id="@+id/btnMiniMinimize"
                android:layout_width="26dp"
                android:layout_height="26dp"
                android:background="@drawable/bg_mini_close_button"
                android:padding="5dp"
                android:scaleType="centerInside"
                android:src="@drawable/ic_chevron_right"
                app:tint="#6b7280" />
        </LinearLayout>

        <!-- Main Content -->
        <LinearLayout
            android:id="@+id/contentArea"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:layout_marginEnd="70dp"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            android:clipChildren="false"
            android:clipToPadding="false">

            <com.google.android.material.imageview.ShapeableImageView
                android:id="@+id/imgMiniAlbum"
                android:layout_width="55dp"
                android:layout_height="55dp"
                android:layout_marginEnd="12dp"
                android:scaleType="centerCrop"
                android:src="@mipmap/ic_launcher"
                app:shapeAppearanceOverlay="@style/RoundedImage" />

            <LinearLayout
                android:id="@+id/infoArea"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical">

                <TextView
                    android:id="@+id/textMiniSongTitle"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:ellipsize="marquee"
                    android:marqueeRepeatLimit="marquee_forever"
                    android:singleLine="true"
                    android:text="Song Title"
                    android:textColor="#FFFFFF"
                    android:textSize="15sp"
                    android:textStyle="bold" />

                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:gravity="center_vertical"
                    android:orientation="horizontal">

                    <ImageView
                        android:id="@+id/premiumBadge"
                        android:layout_width="14dp"
                        android:layout_height="14dp"
                        android:layout_marginEnd="4dp"
                        android:src="@drawable/ic_star_badge"
                        android:tint="#f59e0b"
                        android:visibility="gone" />

                    <TextView
                        android:id="@+id/textMiniArtistName"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:ellipsize="end"
                        android:singleLine="true"
                        android:text="Artist Name"
                        android:textColor="#b3b3b3"
                        android:textSize="12sp" />
                </LinearLayout>
            </LinearLayout>

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:layout_marginStart="12dp"
                android:clipChildren="false"
                android:clipToPadding="false">

                <ImageButton
                    android:id="@+id/btnMiniPrevious"
                    android:layout_width="36dp"
                    android:layout_height="36dp"
                    android:layout_marginEnd="8dp"
                    android:background="@drawable/bg_mini_control_button"
                    android:padding="8dp"
                    android:scaleType="centerInside"
                    android:src="@android:drawable/ic_media_previous"
                    app:tint="#FFFFFF" />

                <FrameLayout
                    android:layout_width="42dp"
                    android:layout_height="42dp"
                    android:clipChildren="false"
                    android:clipToPadding="false">

                    <View
                        android:id="@+id/viewPulseEffect"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:alpha="0"
                        android:background="@drawable/bg_play_gradient"
                        android:scaleX="1.25"
                        android:scaleY="1.25" />

                    <View
                        android:id="@+id/playButtonBackground"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:background="@drawable/bg_play_gradient" />

                    <ImageButton
                        android:id="@+id/btnMiniPlayPause"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:background="?attr/selectableItemBackgroundBorderless"
                        android:padding="9dp"
                        android:scaleType="centerInside"
                        android:src="@android:drawable/ic_media_play"
                        app:tint="#FFFFFF" />
                </FrameLayout>

                <ImageButton
                    android:id="@+id/btnMiniNext"
                    android:layout_width="36dp"
                    android:layout_height="36dp"
                    android:layout_marginStart="8dp"
                    android:background="@drawable/bg_mini_control_button"
                    android:padding="8dp"
                    android:scaleType="centerInside"
                    android:src="@android:drawable/ic_media_next"
                    app:tint="#FFFFFF" />
            </LinearLayout>
        </LinearLayout>

        <!-- Progress / Time -->
        <LinearLayout
            android:id="@+id/progressRow"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/contentArea">

            <TextView
                android:id="@+id/textMiniCurrentTime"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="0:00"
                android:textColor="#9ca3af"
                android:textSize="10sp" />

            <SeekBar
                android:id="@+id/miniPlayerProgress"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginHorizontal="8dp"
                android:layout_weight="1"
                android:paddingStart="10dp"
                android:paddingEnd="10dp"
                android:progress="0"
                android:thumbTint="#FFFFFF"
                android:progressTint="#8b5cf6"
                android:progressBackgroundTint="#33ffffff" />

            <TextView
                android:id="@+id/textMiniDuration"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="0:00"
                android:textColor="#9ca3af"
                android:textSize="10sp" />
        </LinearLayout>

    </androidx.constraintlayout.widget.ConstraintLayout>

    <!-- COLLAPSED STATE -->
    <LinearLayout
        android:id="@+id/miniPlayerCollapsed"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="end|bottom"
        android:layout_marginBottom="10dp"
        android:background="@drawable/bg_mini_player_collapsed"
        android:clickable="true"
        android:elevation="10dp"
        android:focusable="true"
        android:gravity="center"
        android:orientation="horizontal"
        android:paddingHorizontal="18dp"
        android:paddingVertical="12dp"
        android:visibility="gone">

        <ImageView
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:src="@drawable/ic_chevron_right"
            app:tint="#8b5cf6" />
    </LinearLayout>

</FrameLayout>
