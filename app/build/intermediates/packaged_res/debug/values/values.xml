<?xml version="1.0" encoding="utf-8"?>
<resources>
    <string-array name="report_reasons">
        <item>Nội dung bản quyền</item>
        <item>Nội dung không phù hợp</item>
        <item>Chất lượng âm thanh kém</item>
        <item>Thông tin sai lệch</item>
        <item>Khác</item>
    </string-array>
    <color name="accent">#10b981</color>
    <color name="background">#0a0a0a</color>
    <color name="backgroundSecondary">#121212</color>
    <color name="black">#000000</color>
    <color name="border_color">#33FFFFFF</color>
    <color name="card_background">#1e1e1e</color>
    <color name="glass_white">#20FFFFFF</color>
    <color name="glass_white_heavy">#40FFFFFF</color>
    <color name="green_500">#22c55e</color>
    <color name="notification_badge_red">#EF4444</color>
    <color name="primary">#8b5cf6</color>
    <color name="primaryDark">#7c3aed</color>
    <color name="primaryLight">#a78bfa</color>
    <color name="secondary">#ec4899</color>
    <color name="surface">#1e1e1e</color>
    <color name="surfaceVariant">#2a2a2a</color>
    <color name="textMuted">#6b7280</color>
    <color name="textPrimary">#f5f5f5</color>
    <color name="textSecondary">#b3b3b3</color>
    <color name="transparent">#00000000</color>
    <color name="vibrant_blue">#3B82F6</color>
    <color name="vibrant_pink">#EC4899</color>
    <color name="vibrant_purple">#A855F7</color>
    <color name="white">#ffffff</color>
    <string name="app_name">Appad Java Android</string>
    <style name="BottomNavActiveIndicatorStyle" parent="Widget.Material3.BottomNavigationView.ActiveIndicator">
        <item name="android:color">#1A8B5CF6</item>
        <item name="marginHorizontal">4dp</item>
    </style>
    <style name="BottomSheetDialogTheme" parent="Theme.MaterialComponents.BottomSheetDialog">
        <item name="bottomSheetStyle">@style/DarkBottomSheetStyle</item>
        <item name="android:windowIsFloating">false</item>
        <item name="android:windowBackground">@android:color/transparent</item>
        <item name="android:backgroundDimEnabled">true</item>
        <item name="android:backgroundDimAmount">0.7</item>
    </style>
    <style name="ChevronIcon">
        <item name="android:layout_width">20dp</item>
        <item name="android:layout_height">20dp</item>
        <item name="android:src">@drawable/ic_chevron_right</item>
        <item name="android:tint">#888888</item>
    </style>
    <style name="CircleImage" parent="">
        <item name="cornerSize">50%</item>
    </style>
    <style name="CustomBottomSheetDialogTheme" parent="Theme.MaterialComponents.Light.BottomSheetDialog">
        <item name="bottomSheetStyle">@style/CustomBottomSheetStyle</item>
    </style>
    <style name="CustomBottomSheetStyle" parent="Widget.Design.BottomSheet.Modal">
        <item name="android:background">@android:color/transparent</item>
    </style>
    <style name="CustomTabText" parent="TextAppearance.Design.Tab">
        <item name="android:textSize">16sp</item>
        <item name="android:textStyle">bold</item>
        <item name="android:textAllCaps">false</item>
    </style>
    <style name="DarkBottomSheetStyle" parent="Widget.Design.BottomSheet.Modal">
        <item name="android:background">@android:color/transparent</item>
        <item name="behavior_peekHeight">auto</item>
        <item name="behavior_fitToContents">true</item>
    </style>
    <style name="PremiumBodyText">
        <item name="android:textColor">#B3FFFFFF</item>
        <item name="android:textSize">14sp</item>
        <item name="android:fontFamily">sans-serif</item>
    </style>
    <style name="PremiumButton">
        <item name="android:textAllCaps">false</item>
        <item name="android:textColor">#FFFFFF</item>
        <item name="android:backgroundTint">#8b5cf6</item>
        <item name="cornerSize">12dp</item>
    </style>
    <style name="PremiumTitleText">
        <item name="android:textColor">#FFFFFF</item>
        <item name="android:textSize">20sp</item>
        <item name="android:textStyle">bold</item>
        <item name="android:fontFamily">sans-serif-bold</item>
    </style>
    <style name="Rounded16">
        <item name="cornerFamily">rounded</item>
        <item name="cornerSize">16dp</item>
    </style>
    <style name="RoundedCornerImage24">
        <item name="cornerFamily">rounded</item>
        <item name="cornerSize">24dp</item>
    </style>
    <style name="RoundedImage" parent="">
        <item name="cornerSize">8dp</item>
    </style>
    <style name="RoundedImage8">
        <item name="cornerFamily">rounded</item>
        <item name="cornerSize">8dp</item>
    </style>
    <style name="RoundedImageLarge" parent="">
        <item name="cornerSize">20dp</item>
    </style>
    <style name="RoundedImageView" parent="">
        <item name="cornerSize">12dp</item>
    </style>
    <style name="SearchTabText" parent="TextAppearance.Design.Tab">
        <item name="android:textSize">16sp</item>
        <item name="android:textStyle">bold</item>
        <item name="android:textAllCaps">false</item>
    </style>
    <style name="TabTextAppearance" parent="TextAppearance.Design.Tab">
        <item name="android:textSize">14sp</item>
        <item name="android:textStyle">bold</item>
        <item name="android:textAllCaps">false</item>
    </style>
    <declare-styleable name="ProfileMenuItemView">
        <attr format="string" name="itemTitle"/>
        <attr format="string" name="itemSubtitle"/>
        <attr format="reference" name="itemIcon"/>
        <attr format="color" name="itemColor"/>
    </declare-styleable>
</resources>